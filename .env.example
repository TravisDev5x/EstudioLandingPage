# Base de datos MySQL
DATABASE_URL="mysql://usuario:password@host:puerto/basededatos"

# NextAuth — genera AUTH_SECRET con: npx auth secret
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Envío de correos (Resend SMTP)
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_FROM="onboarding@resend.dev"
RESEND_API_KEY=""

# Rate limiting (Upstash Redis) — opcional, ver README.
# Si se dejan vacías, el rate limiting queda deshabilitado (fail-open).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
